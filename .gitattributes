# Set default behavior to handle all files as text and normalize to LF
* text=auto eol=lf

# Explicitly mark file types to be normalized as LF
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.tf text eol=lf
*.tfvars text eol=lf
.env* text eol=lf
.gitignore text eol=lf
.prettierrc text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Mark lockfiles and generated files
package-lock.json linguist-generated
pnpm-lock.yaml linguist-generated
yarn.lock linguist-generated
bun.lockb linguist-generated
uv.lock linguist-generated
poetry.lock linguist-generated
.terraform.lock.hcl linguist-generated
