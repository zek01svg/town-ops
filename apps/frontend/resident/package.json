{
  "name": "@townops/resident-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "NODE_ENV=production bun build/index.js",
    "build": "bun run load-env -- vite build && tsc && bun build --minify --sourcemap --target=bun --outdir=build server/index.ts",
    "build:docker": "bun run build && docker build -t resident-frontend .",
    "preview": "vite preview",
    "clean": "rimraf build node_modules .tanstack coverage",
    "lint": "bun run oxlint -c ../../../tooling/oxlint/oxlint.config.ts",
    "test": "bun run load-env -- vitest run tests --coverage",
    "load-env": "dotenv -e .env"
  },
  "dependencies": {
    "@fontsource-variable/inter": "catalog:",
    "@fontsource/space-grotesk": "catalog:",
    "@hugeicons/core-free-icons": "catalog:",
