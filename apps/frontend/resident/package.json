    "@sentry/react": "catalog:",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-table": "catalog:",
    "@tanstack/zod-form-adapter": "catalog:",
    "@townops/accept-job-composite": "workspace:*",
    "@townops/assign-job-composite": "workspace:*",
    "@townops/close-case-composite": "workspace:*",
    "@townops/handle-breach-composite": "workspace:*",
    "@townops/open-case-composite": "workspace:*",
    "@townops/reschedule-job-composite": "workspace:*",
    "@townops/shared-ts": "workspace:*",
    "@townops/ui": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-kanban-kit": "catalog:",
    "tw-animate-css": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@t3-oss/env-core": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/devtools": "catalog:",
    "@tanstack/devtools-vite": "catalog:",
