# Reschedule Job Service Configuration (Composite Service - Port 60xx)

# Service Configuration
RESCHEDULE_JOB_PORT=6006
DEBUG=false

# Atomic Services (Port 50xx)
RESIDENT_URL=http://resident:5002
APPOINTMENT_URL=http://appointment:5004
CASE_URL=http://case:5001

# Global Infrastructure
RABBITMQ_URL=amqp://guest:guest@localhost:5672
POSTGRES_USER=hdbcare_admin
POSTGRES_PASSWORD=securepassword

# Timeouts (seconds)
HTTP_TIMEOUT=10.0
HTTP_CONNECT_TIMEOUT=5.0

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
PORT=6006
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
DATABASE_URL=postgresql://hdbcare_admin:securepassword@db:5432/reschedule-job_db
