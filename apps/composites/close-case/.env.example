PORT=6004

# Downstream atomic services
CASE_SERVICE_URL=http://case-service:8000
PROOF_SERVICE_URL=http://proof-service:8000

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
JOB_DONE_EXCHANGE=townops.events
JOB_DONE_ROUTING_KEY=job.done

# HTTP client timeout (seconds)
HTTP_TIMEOUT=10

# Observability (optional — leave blank to disable OTLP export)
ENV=development
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
