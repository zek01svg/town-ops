{
  "name": "townops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "prepare": "husky",
    "format": "prettier --config tooling/prettier/prettier.config.js --write .",
    "lint:py": "uv run ruff check . --config tooling/ruff/ruff.toml",
    "lint:js": "eslint . --config tooling/eslint/eslint.config.mjs"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@hono/eslint-config": "^2.1.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "eslint": "^9.21.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript-eslint": "^8.57.0"
  }
}
