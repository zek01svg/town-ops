{
  "name": "townops",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "format:fix": "pnpm oxfmt --config tooling/oxfmt/.oxfmtrc.json --write .",
    "format:check": "pnpm oxfmt --config tooling/oxfmt/.oxfmtrc.json --check .",
    "lint:py": "uv run ruff check . --config tooling/ruff/ruff.toml",
    "lint:js": "pnpm oxlint --config=tooling/oxlint/oxlint.config.ts",
    "clean": "pnpm rimraf node_modules .turbo"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.17",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.30.1"
}
