{
  "name": "townops",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/**",
    "packages/**"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "format:fix": "pnpm oxfmt --config tooling/oxfmt/.oxfmtrc.json --write .",
    "format:check": "pnpm oxfmt --config tooling/oxfmt/.oxfmtrc.json --check .",
    "lint:py": "uv run ruff check . --config tooling/ruff/ruff.toml",
    "lint:js": "pnpm oxlint --config=tooling/oxlint/oxlint.config.ts",
    "clean": "pnpm turbo run clean",
    "dev": "pnpm turbo run dev --concurrency=20",
    "build": "pnpm turbo run build",
    "start": "pnpm turbo run start",
    "test": "pnpm turbo run test"
  },
  "dependencies": {
    "@cloudamqp/amqp-client": "^3.4.1",
    "@supabase/supabase-js": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@hono/standard-validator": "catalog:",
    "@playwright/test": "^1.59.1",
    "@scalar/hono-api-reference": "catalog:",
    "@testcontainers/postgresql": "catalog:",
    "@testcontainers/rabbitmq": "catalog:",
    "@types/pg": "catalog:",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "dotenv-cli": "catalog:",
    "drizzle-kit": "catalog:",
    "hono-openapi": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "rimraf": "catalog:",
    "turbo": "^2.9.3",
    "typescript": "catalog:",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0"
}
